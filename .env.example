# Flask Configuration
FLASK_ENV=development
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
SECRET_KEY=your_secret_key_change_in_production

# Database Servers (Production)
# Uncomment dan update untuk production
# DATABASE_PASSWORD_SERVER1=your_actual_password
# DATABASE_PASSWORD_SERVER2=your_actual_password

# Logging
LOG_LEVEL=INFO

# Session
SESSION_TIMEOUT_HOURS=8
